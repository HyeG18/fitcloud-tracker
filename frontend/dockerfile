# ==========================================
# Etapa 1: Construcción (Build)
# ==========================================
FROM node:20-alpine AS build

# Establecer el directorio de trabajo dentro del contenedor
WORKDIR /app

# Instalar pnpm globalmente en este contenedor base
RUN npm install -g pnpm

# Copiar solo los archivos de dependencias primero para aprovechar el caché de Docker
COPY package.json pnpm-lock.yaml ./

# Instalar las dependencias usando pnpm
RUN pnpm install

# Copiar el resto del código fuente del frontend
COPY . .

# Construir la aplicación para producción (Vite genera los archivos en /app/dist)
RUN pnpm run build

# ==========================================
# Etapa 2: Servidor Web (Producción)
# ==========================================
FROM nginx:alpine

# Eliminar los archivos por defecto de Nginx
RUN rm -rf /usr/share/nginx/html/*

# Copiar los archivos estáticos compilados desde la Etapa 1
COPY --from=build /app/dist /usr/share/nginx/html

# Exponer el puerto 80 para el tráfico web
EXPOSE 80

# Comando por defecto para iniciar Nginx y mantenerlo corriendo en primer plano
CMD ["nginx", "-g", "daemon off;"]